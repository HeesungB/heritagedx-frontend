{
  "name": "@heritage-dx/gh-agent-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local daemon that bridges GitHub issues/PRs to Claude/Codex CLI agents.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --max-warnings=0",
    "test:smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.0",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
