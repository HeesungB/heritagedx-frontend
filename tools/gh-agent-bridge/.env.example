# GitHub App credentials (preferred over PAT for rate-limit isolation)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/Users/heesungbae/.config/gh-agent-bridge/app-private-key.pem
GITHUB_APP_INSTALLATION_ID=
# Repo this daemon serves
GITHUB_OWNER=HeesungB
GITHUB_REPO=heritage-dx
# Webhook secret you set when registering the GitHub App webhook
GITHUB_WEBHOOK_SECRET=

# Daemon HTTP server
PORT=7878
HOST=127.0.0.1
PUBLIC_WEBHOOK_URL=https://gh-bridge.blackmarket.kr/webhook

# CLI paths (absolute). Verified via `which`.
CLAUDE_CLI=/Applications/cmux.app/Contents/Resources/bin/claude
CODEX_CLI=/Users/heesungbae/.nvm/versions/node/v22.22.0/bin/codex
GH_CLI=/opt/homebrew/bin/gh

# Repo to operate on (the cloned working copy used to create worktrees)
REPO_DIR=/Users/heesungbae/heritage-dx
WORKTREE_ROOT=/Users/heesungbae/heritage-dx/.worktrees

# SQLite state location
DB_PATH=/Users/heesungbae/.local/share/gh-agent-bridge/state.db

# Concurrency
WORKER_CONCURRENCY=4

# Daily token cap (combined across both agents, USD)
DAILY_BUDGET_USD=20

# Login allowlist: comma-separated GitHub logins whose comments are honored.
# The daemon's own bot user is auto-added to a deny list.
ALLOWED_LOGINS=HeesungB

# Logging
LOG_LEVEL=info

# Screenshot worker
SCREENSHOT_OS_PORT=3100
SCREENSHOT_BO_PORT=3101
SCREENSHOT_TIMEOUT_MS=20000
