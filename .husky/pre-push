#!/usr/bin/env sh
# main 브랜치 직접 push 차단 — 모든 변경은 PR 을 통해 머지한다.
# 우회가 꼭 필요한 경우(예: CI 워크플로우 자체 수정)에만 `git push --no-verify` 사용.

protected_branch="main"

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
    printf "\n\033[31m❌ %s 브랜치로 직접 push 가 차단되었습니다.\033[0m\n" "$protected_branch"
    printf "   PR 을 열고 CI 통과 후 머지하세요.\n"
    printf "   불가피한 경우에만 --no-verify 로 우회 가능합니다.\n\n"
    exit 1
  fi
done

exit 0
